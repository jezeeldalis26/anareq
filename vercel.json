{
  "": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/login",
      "destination": "/"
    },
    {
      "source": "/registro",
      "destination": "/"
    },
    {
      "source": "/app",
      "destination": "/"
    },
    {
      "source": "/app/:path*",
      "destination": "/"
    }
  ]
}